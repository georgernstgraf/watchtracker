<!-- fragments/user-watches.hbs -->
<div id='userWatches'
     x-data="{
         sortBy: 'recent_desc',
         gridReady: false,
         validSorts: ['recent_desc', 'recent_asc', 'precise_asc', 'precise_desc'],
         init() {
             const storedSort = localStorage.getItem('watchtracker-sortBy');
             this.sortBy = this.validSorts.includes(storedSort) ? storedSort : 'recent_desc';
             this.$refs.watchGrid.addEventListener('htmx:afterSwap', () => {
                 this.applySort();
                 this.gridReady = true;
             });
             this.loadGrid();
         },
         loadGrid() {
             this.gridReady = false;
             htmx.ajax('GET', '{{appPath}}/watches', { target: this.$refs.watchGrid, swap: 'innerHTML' });
         },
         setSort(sort) {
             if (!this.validSorts.includes(sort)) {
                 return;
             }
             this.sortBy = sort;
             localStorage.setItem('watchtracker-sortBy', sort);
             this.applySort();
         },
         applySort() {
             const grid = this.$refs.watchGrid.querySelector('[data-watch-grid]');
             if (!grid) {
                 return;
             }

             const [sortKey, sortDirection] = this.sortBy.split('_');
             const cards = Array.from(grid.querySelectorAll('[data-watch-card]'));
             const sortedCards = [...cards].sort((cardA, cardB) => {
                 const valueA = this.getSortValue(cardA, sortKey);
                 const valueB = this.getSortValue(cardB, sortKey);
                 return sortDirection === 'asc' ? valueA - valueB : valueB - valueA;
             });

             sortedCards.forEach((card) => grid.appendChild(card));
         },
         getSortValue(card, sortKey) {
             if (sortKey === 'recent') {
                 return Number(card.dataset.lastUsedTimestamp || '0');
             }
             return Number(card.dataset.absoluteDrift || 'Infinity');
         }
     }"
     x-init="init()">
    <!-- Sort Controls -->
    <div class="d-flex justify-content-between mb-2">
        <button type="button"
                class="btn btn-outline-secondary btn-sm"
                :class="{ 'active': sortBy === 'recent_desc' }"
                @click="setSort('recent_desc')">
            Recent ↓
        </button>
        <button type="button"
                class="btn btn-outline-secondary btn-sm"
                :class="{ 'active': sortBy === 'recent_asc' }"
                @click="setSort('recent_asc')">
            Recent ↑
        </button>
        <button type="button"
                class="btn btn-outline-secondary btn-sm"
                :class="{ 'active': sortBy === 'precise_asc' }"
                @click="setSort('precise_asc')">
            Precise ↓
        </button>
        <button type="button"
                class="btn btn-outline-secondary btn-sm"
                :class="{ 'active': sortBy === 'precise_desc' }"
                @click="setSort('precise_desc')">
            Precise ↑
        </button>
    </div>
    <!-- Watch Cards Grid -->
    <div id="watchGrid"
         x-ref="watchGrid"
         style="display: none;"
         x-show="gridReady"></div>

    <!-- Add Watch Button -->
    <button id="watchCreateBtn"
            class="btn btn-outline-secondary w-100 py-3 fs-5 fw-semibold"
            hx-get="{{appPath}}/watch/new"
            hx-target="#mainContent"
            hx-swap="innerHTML">
        Add new Watch
    </button>
</div>
<!-- /fragments/user-watches.hbs -->
